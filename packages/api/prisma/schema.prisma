generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./symphony.db"
}

model Issue {
  id           String   @id @default(cuid())
  title        String
  description  String
  status       String   @default("todo") // todo, in_progress, in_review, done
  assignee     String?  // human, ai
  agentStatus  String?  // initializing, writing_code, waiting_input, completed
  workspaceUrl String?
  startTime    DateTime?
  agentConfig  String?  // JSON serialized
  parentId     String?
  parent       Issue?   @relation("IssueToIssue", fields: [parentId], references: [id])
  children     Issue[]  @relation("IssueToIssue")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
